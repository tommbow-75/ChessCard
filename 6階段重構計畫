### 步驟 2-C：建立 `target_piece_mask.gd`

路徑：`scripts/CardEffectLayers/target_piece_mask.gd`

```gdscript
class_name TargetPieceMask
extends Resource

## 對應 XiangqiPiece.PieceType 的 bitmask 常數
const GENERAL  := 1   # bit 0
const ADVISOR  := 2   # bit 1
const ELEPHANT := 4   # bit 2
const HORSE    := 8   # bit 3
const CHARIOT  := 16  # bit 4
const CANNON   := 32  # bit 5
const SOLDIER  := 64  # bit 6
const DEFAULT_MASK := 127 # 預設全選（不含空格）

@export_flags("General", "Advisor", "Elephant", "Horse", "Chariot", "Cannon", "Soldier")
var mask: int = DEFAULT_MASK

## 判斷指定的 PieceType 是否符合此 mask
func matches(piece_type: int) -> bool:
    var bit := 0
    match piece_type:
        XiangqiPiece.PieceType.GENERAL:  bit = GENERAL
        XiangqiPiece.PieceType.ADVISOR:  bit = ADVISOR
        XiangqiPiece.PieceType.ELEPHANT: bit = ELEPHANT
        XiangqiPiece.PieceType.HORSE:    bit = HORSE
        XiangqiPiece.PieceType.CHARIOT:  bit = CHARIOT
        XiangqiPiece.PieceType.CANNON:   bit = CANNON
        XiangqiPiece.PieceType.SOLDIER:  bit = SOLDIER
        _: return false
    return (mask & bit) != 0
```

