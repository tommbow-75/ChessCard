# Phase 3 — 重構 L1 基底：注入新 Resource 欄位

> **目標：** 讓 `strategy_effect_timing.gd` 使用 Phase 2 建立的 Resource，並保留原有的驗證邏輯（改寫以呼叫 Resource 的方法）。
> **風險：** 高（是最核心的改動，影響所有謀略卡效果）
> **完成條件：** `is_valid_target()` 與 `get_affected_cells()` 仍可正常運作

### 步驟 3-A：改寫 `strategy_effect_timing.gd`

```gdscript
class_name StrategyEffectTiming
extends Resource

## ── L2~L5：可組合的 Resource 欄位 ──────────────────────────────────
@export var target_type: TargetType       ## L2：目標類型
@export var effect_target: EffectTarget   ## L3：陣營方向
@export var piece_mask: TargetPieceMask   ## L4：棋子種類過濾
@export var target_mode: TargetMode       ## L5：作用範圍

## ── 目標驗證 ────────────────────────────────────────────────────────
## 回傳 true 代表此格可被玩家點選為目標
func is_valid_target(board_pos: Vector2i, context: Dictionary) -> bool:
    if target_type == null or target_type.type == TargetType.Type.PLAYER:
        return false  # PLAYER 型不需選格
    if target_mode == null or target_mode.mode == TargetMode.Mode.NONE:
        return false
    if target_mode.mode == TargetMode.Mode.GLOBAL:
        return false  # GLOBAL 型不需玩家選格

    var game = context.get("game")
    if game == null:
        return false

    if target_mode.mode == TargetMode.Mode.AREA_3X3:
        return true  # 3x3 模式：任何格皆可當中心

    # SINGLE 模式：嚴格驗證
    return _cell_matches(board_pos, game, context.get("caster_side"))

## ── 取得效果的實際作用格列表 ─────────────────────────────────────────
func get_affected_cells(center: Vector2i, context: Dictionary) -> Array[Vector2i]:
    var result: Array[Vector2i] = []
    if target_type == null or target_type.type == TargetType.Type.PLAYER:
        return result
    var game = context.get("game")
    if game == null:
        return result
    var side = context.get("caster_side")

    match target_mode.mode if target_mode else TargetMode.Mode.NONE:
        TargetMode.Mode.SINGLE:
            if _cell_matches(center, game, side):
                result.append(center)
        TargetMode.Mode.AREA_3X3:
            for dx in range(-1, 2):
                for dy in range(-1, 2):
                    var p = Vector2i(center.x + dx, center.y + dy)
                    if not game.board.is_out_of_bounds(p):
                        if _cell_matches(p, game, side):
                            result.append(p)
        TargetMode.Mode.GLOBAL:
            for y in range(10):
                for x in range(9):
                    var p = Vector2i(x, y)
                    if _cell_matches(p, game, side):
                        result.append(p)
    return result

## ── 效果執行（子類 override）─────────────────────────────────────────
## context 包含：
##   "game": XiangqiGame
##   "caster_side": int（Side）
##   "target_pos": Vector2i（-1,-1 代表不需選格）
##   "affected_positions": Array[Vector2i]
func execute(_context: Dictionary) -> void:
    pass

## ── 私有：判斷單格是否符合 L3+L4 ────────────────────────────────────
func _cell_matches(pos: Vector2i, game, caster_side: int) -> bool:
    var piece = game.board.get_piece(pos)
    var enemy_side = XiangqiPiece.Side.BLACK \
        if caster_side == XiangqiPiece.Side.RED \
        else XiangqiPiece.Side.RED

    if piece == null:
        return false  # 新架構不處理空格（cell 型由 target_type 控制）

    # L3：陣營驗證
    if effect_target != null:
        match effect_target.target:
            EffectTarget.Target.SELF:
                if piece.side != caster_side: return false
            EffectTarget.Target.ENEMY:
                if piece.side != enemy_side: return false
            EffectTarget.Target.ANY:
                pass  # 不限

    # L4：棋子種類驗證
    if piece_mask != null:
        return piece_mask.matches(piece.type)
    return true
```

